# .env.example — Cliosphere root environment
# Copy to .env and fill in values. NEVER commit .env to git.
# Ansible sets this file per host during provisioning.

# ── Third-party agent tooling ────────────────────────────────────────────────
# Suppress Azure Copilot Skills telemetry hook (fires on every tool call in Gemini CLI).
# Safe to leave as false on all hosts — no Azure services used in Cliosphere.
AZURE_MCP_COLLECT_TELEMETRY=false

# ── AI API Keys ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ── Gemini / Antigravity CLI ──────────────────────────────────────────────────
# Disables Microsoft Azure telemetry hook that fires on every tool call.
# The hook ships with Gemini CLI's default Azure Copilot Skills package.
# Set to false always — Cliosphere does not use Azure skills.
AZURE_MCP_COLLECT_TELEMETRY=false

# ── Ollama (WSL2 / VPS) ───────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_PRIMARY_MODEL=ollama/qwen2.5-coder:7b

# ── Embedding provider ────────────────────────────────────────────────────────
# Mac:  http://host.docker.internal:1234  (MLX-LM)
# WSL2: http://127.0.0.1:11434            (Ollama)
# VPS:  http://host.docker.internal:11434 (Ollama)
# Leave blank to enable auto-detection fallback.
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=nomic-embed-text

# ── OpenClaw ──────────────────────────────────────────────────────────────────
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_GATEWAY_PORT=18789

# ── RAG ───────────────────────────────────────────────────────────────────────
RAG_PORT=8000
CHROMA_COLLECTION=clio_knowledge

# ── Docker networking ─────────────────────────────────────────────────────────
# Overridden by compose override files — usually don't set here.
# DOCKER_NETWORK_MODE=host

# ── HashiCorp Vault ───────────────────────────────────────────────────────────
# Dev mode only (Mac + WSL2). Root token for the in-memory dev server.
# Generate any string you want — this IS the root credential in dev mode.
# On VPS, Vault runs in server mode and is initialized separately (vault operator init).
VAULT_DEV_TOKEN=

# ── LiteLLM ───────────────────────────────────────────────────────────────────
# Master key for LiteLLM virtual key issuance and admin API.
# Used by agents and OpenClaw to authenticate against clio-litellm.
# Generate with: openssl rand -hex 32
LITELLM_MASTER_KEY=
