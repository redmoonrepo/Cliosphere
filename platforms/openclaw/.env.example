# platforms/openclaw/.env.example
# Copy to .env and fill in values. NEVER commit .env to git.
# All variables here are injected into the container via docker-compose.yml.
# Tool OAuth credentials (gh, claude, gemini) are stored in ~/.clio-home/
# and persist across container rebuilds via the clio-home Docker volume.

# ── AI API Keys ───────────────────────────────────────────────────────────────

# Gemini AI Studio (free tier — Clio's primary free fallback)
GEMINI_API_KEY=

# Anthropic — Claude Code + Sonnet/Opus fallback routing
ANTHROPIC_API_KEY=

# ── Local Model (Ollama) ──────────────────────────────────────────────────────

# Ollama host — WSL2 host networking, loopback reachable from container
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Primary local model
OLLAMA_PRIMARY_MODEL=ollama/qwen2.5-coder:7b

# ── OpenClaw ──────────────────────────────────────────────────────────────────

# Gateway auth token (generate: openclaw doctor --generate-gateway-token)
OPENCLAW_GATEWAY_TOKEN=

# Gateway port (default: 18789)
OPENCLAW_GATEWAY_PORT=18789

# ── Google (cliosphere.ai@gmail.com) ─────────────────────────────────────────
# OAuth credentials for Google Drive MCP are stored in ~/.clio-home/.config/
# after running: npx @modelcontextprotocol/server-gdrive auth
# No env var needed — the MCP server reads from its config directory.
# Drive is used for cross-platform file access:
#   Gemini web, ChatGPT web, Claude web can read Clio files from Drive
#   Upload on significant changes: gemini upload --drive <file>

# ── Future keys (add here as services are added) ──────────────────────────────
# GITHUB_TOKEN=          # if GitHub CLI needs non-interactive auth
# OPENAI_API_KEY=        # if OpenAI is added to the model roster
# DISCORD_TOKEN=         # if Discord channel is enabled
# TELEGRAM_BOT_TOKEN=    # if Telegram channel is enabled
