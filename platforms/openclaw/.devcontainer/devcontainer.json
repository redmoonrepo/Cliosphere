{
  "name": "Cliosphere - OpenClaw Platform",

  // Reference the compose file one level up (platforms/openclaw/)
  "dockerComposeFile": ["../docker-compose.yml"],
  "service": "openclaw-gateway",
  "workspaceFolder": "/workspaces/Cliosphere",

  // Run after container is created — lightweight only
  // Heavy deps are baked into setup-tools.sh (run once manually or on rebuild)
  "postCreateCommand": "bash /workspaces/Cliosphere/platforms/openclaw/scripts/post-create.sh",

  "remoteUser": "node",

  "customizations": {
    "vscode": {
      "extensions": [
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "ms-azuretools.vscode-docker",
        "ms-vscode.makefile-tools",
        "redhat.vscode-yaml"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "editor.formatOnSave": true
      }
    }
  },

  // Forward OpenClaw gateway port to host for browser access
  "forwardPorts": [18789],
  "portsAttributes": {
    "18789": {
      "label": "OpenClaw Gateway",
      "onAutoForward": "notify"
    }
  }
}
