{
  "name": "Cliosphere - OpenClaw Platform",

  // docker-compose.yml is generated by Ansible per host — single file, no overrides needed.
  // Run before opening Dev Container:
  //   ansible-playbook -i infra/inventory/hosts.yml infra/playbooks/site.yml --limit mac-mathew
  "dockerComposeFile": ["../docker-compose.yml"],
  "service": "openclaw",
  "workspaceFolder": "/workspaces/Cliosphere",

  "remoteUser": "node",

  "customizations": {
    "vscode": {
      "extensions": [
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "ms-azuretools.vscode-docker",
        "ms-vscode.makefile-tools",
        "redhat.vscode-yaml"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "editor.formatOnSave": true
      }
    }
  },

  "forwardPorts": [18789, 8000],
  "portsAttributes": {
    "18789": {
      "label": "OpenClaw Gateway",
      "onAutoForward": "notify"
    },
    "8000": {
      "label": "Clio RAG Service",
      "onAutoForward": "notify"
    }
  }
}
